NOOK_COVER_OUTPUT_DIR=./output
NOOK_COVER_DEFAULT_PROVIDER=none

# Optional sibling tools. Leave empty if the tool is not installed.
# Run `node scripts/setup-provider.cjs` to auto-detect sibling tools.
NOOK_ZIMAGE_PATH=
NOOK_QWEN_IMAGE_PATH=
NOOK_IMAGE2_GPT_PATH=

# Provider env is owned by each atomic tool, not by nook-cover.
# nook-cover only records where those tools are and which route to prefer.
# Configure keys in each tool:
#   nook-zimage: node setup.js, writes MS_API_KEY / MS_API_BASE_URL
#   nook-qwen-image: node setup.js, writes MS_API_KEY / MS_API_BASE_URL
#   nook-image2-gpt: node setup.js, writes IMAGE_API_KEY / IMAGE_API_BASE_URL
