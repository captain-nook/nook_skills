# Required: API key for your image relay service
IMAGE_API_KEY=sk-your-key-here

# Required: your relay base URL (OpenAI-compatible)
# IMAGE_API_BASE_URL=https://your-relay-server/v1

# Optional: model name (default: gpt-image-2)
# IMAGE_MODEL=gpt-image-2

# Optional: set to false to enable real API calls (default: true)
# IMAGE_DRY_RUN=false
